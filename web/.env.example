# Backend origin without a trailing slash.
VITE_API_URL=http://localhost:4000
# LOCAL PERSONAL DASHBOARD ONLY. Vite inlines this into the JS bundle — never
# deploy the web app publicly with a real API token, and never reuse production
# API_TOKEN here. Prefer the iOS app for day-to-day use.
VITE_API_TOKEN=dev-token-change-me
# Must match API_TOKEN_USER_ID on the backend (shared token is bound to one user).
VITE_USER_ID=demo-user
